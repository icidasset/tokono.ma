-- | (• ◡•)| (❍ᴥ❍ʋ)


cat k v =
    { key = k
    , value = Array.sortBy .title v
    }


x title url =
    { title = title
    , url = url
    , emoji = Nothing
    }


z emoji title url =
    { title = title
    , url = url
    , emoji = Just emoji
    }
